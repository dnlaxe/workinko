{
  "name": "workinko",
  "version": "1.0.0",
  "description": "",
  "main": "dist/app.js",
  "scripts": {
    "server:dev": "tsx watch src/server.ts",
    "css:dev": "npx @tailwindcss/cli -i ./src/input.css -o ./public/styles.css --watch",
    "dev": "concurrently -n server,css \"npm:server:dev\" \"npm:css:dev\"",
    "build:server": "tsc",
    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./public/styles.css",
    "build": "npm run build:server && npm run build:css",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "compression": "^1.8.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-handlebars": "^8.0.6",
    "helmet": "^8.1.0",
    "pg": "^8.19.0",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
