{{> admin-navbar}}

<a href="/admin/liveposts">← Back to live posts</a>
<h1>Live Post {{post.id}} — {{post.heading}}</h1>

<div class="p-2 border-b">
  <p><strong>ID</strong> {{post.id}}</p>
  <p><strong>Email</strong> {{post.email}}</p>
  <p><strong>Session ID</strong> {{post.sessionId}}</p>
  <p><strong>Heading</strong> {{post.heading}}</p>
  <p><strong>Subheading</strong> {{post.subheading}}</p>
  <p><strong>Category</strong> {{post.category}}</p>
  <p><strong>Specialization</strong> {{post.specialization}}</p>
  <p><strong>Contract type</strong> {{post.contractType}}</p>
  <p><strong>Province</strong> {{post.province}}</p>
  <p><strong>City</strong> {{post.city}}</p>
  <p><strong>Korean proficiency</strong> {{post.koreanProficiency}}</p>
  <p><strong>English proficiency</strong> {{post.englishProficiency}}</p>
  <p><strong>Other languages</strong> {{post.otherLanguages}}</p>
  <p><strong>Visa sponsorship</strong> {{post.visaSponsorship}}</p>
  <p><strong>Start date</strong> {{post.startDate}}</p>
  <p><strong>Contact method</strong> {{post.contactMethod}}</p>
  <p><strong>Contact URL</strong> {{post.contactUrl}}</p>
  <p><strong>Contact email</strong> {{post.contactEmail}}</p>
  <p><strong>Description</strong> {{post.fullDescription}}</p>
  <p><strong>Tier</strong> {{post.tier}}</p>
  <p><strong>Slug</strong> {{post.slug}}</p>
  <p><strong>Published at</strong> {{post.publishedAt}}</p>
  <p><strong>Expires at</strong> {{post.expiresAt}}</p>
</div>
