{{> admin-navbar}}

<div class="flex flex-col gap-4 p-4">
  {{#if serverError}}
    <p class="text-slate-500 text-sm p-4">{{serverError}}</p>
  {{else if messages}}
    {{#each messages}}
      <div class="border border-[#CBCCCE] rounded">
        <div class="flex flex-row">
          <div class="w-8 border-r border-[#CBCCCE] bg-slate-100"></div>
          <div class="flex-1">
            <div class="border-b border-[#CBCCCE] px-4 py-2">
              <div class="flex flex-col text-slate-700">
                <span>From: {{fromEmail}}</span>
                <span>To: {{toEmail}}</span>
              </div>
            </div>
            <div class="border-b border-[#CBCCCE] px-4 py-2">
              <span>{{message}}</span>
            </div>
            <div class="flex px-4 py-2 gap-4">
              <form method="POST" action="/admin/relay/{{id}}/approve">
                <button type="submit" class="rounded-full bg-green-500 text-white hover:bg-green-600 px-4 py-1">Approve</button>
              </form>
              <form method="POST" action="/admin/relay/{{id}}/reject">
                <button type="submit" class="rounded-full bg-slate-500 text-white px-4 py-1">Reject</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    {{/each}}
  {{else}}
    <p class="text-slate-500 text-sm p-4">No pending messages.</p>
  {{/if}}
</div>
