{{> admin-navbar}}

<div>

  <p class="font-bold p-4">Relay Messages</p>

  {{#if actionError}}
    <p class="text-red-500 text-sm border border-red-500 py-1 px-2 rounded inline-block">{{actionError}}</p>
  {{else if messages}}
    {{#each messages}}
      <div class="flex flex-col gap-2 p-4 border-t border-slate-200">
        <div>From: {{fromEmail}}</div>
        <div>To: {{toEmail}}</div>
        <div>{{message}}</div>
  <div class="flex gap-2">
          <form method="POST" action="/admin/relay/{{id}}/approve">
            <button type="submit" class="hover:cursor-pointer font-mono tracking-wide border border-slate-200 hover:border-black text-sm uppercase py-1 px-3">Approve</button>
          </form>
          <form method="POST" action="/admin/relay/{{id}}/reject">
            <button type="submit" class="hover:cursor-pointer font-mono tracking-wide border border-slate-200 hover:border-black text-sm uppercase py-1 px-3">Reject</button>
          </form>
        </div>
      </div>
    {{/each}}
  {{else}}
    <p class="text-slate-500 text-sm p-4">No pending messages.</p>
  {{/if}}

</div>
