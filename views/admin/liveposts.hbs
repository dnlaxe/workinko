{{> admin-navbar}}

<div class="flex flex-col md:border-x border-[#CBCCCE]">

  <p class="text-sm uppercase tracking-widest p-4">Live Posts</p>

  {{#if actionError}}
    <p class="text-red-500 text-sm border border-red-500 py-1 px-2 rounded inline-block">{{actionError}}</p>
  {{else}}
    {{#each posts}}
      <div class="border-t border-[#CBCCCE] px-4 py-3 flex flex-col gap-1">
        <div class="font-sans">{{this.heading}}</div>
        <div class="flex gap-4 text-sm">
          <span>{{this.email}}</span>
          <span>published {{this.publishedAt}}</span>
          <span>expires {{this.expiresAt}}</span>
        </div>
        <a href="/admin/liveposts/{{this.id}}" class="underline text-sm">See details</a>
      </div>
    {{else}}
      <p class="text-slate-500 text-sm p-4">No live posts.</p>
    {{/each}}
  {{/if}}

</div>
