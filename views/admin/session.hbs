{{> admin-navbar}}

<div>

  <div class="p-4">
    <a href="/admin/queue" class="underline">Back to queue</a>
  </div>

      <div class="flex flex-col gap-2 p-4 border-t border-slate-200">
    <div>{{session.email}}</div>
      <div>{{session.status}}</div>
      <div>created {{session.createdAt}}</div>
      <div>updated {{session.updatedAt}}</div>
      <div>expires {{session.expiresAt}}</div>
    <div>ID: {{session.id}}</div>
  </div>

  {{#each jobs}}
    <div class="flex flex-col gap-2 p-4 border-t border-slate-200">
      <div>{{this.heading}}</div>
      <div>{{this.subheading}}</div>
      <div>{{this.specialization}}</div>
      <div>{{this.startDate}}</div>
      <div>{{this.province}}, {{this.city}}</div>
      <div>{{this.contractType}}</div>
      <div>Korean: {{this.koreanProficiency}}</div>
      <div>English: {{this.englishProficiency}}</div>
        {{#if this.otherLanguages}}<div>Other: {{this.otherLanguages}}</div>{{/if}}
      <div>Visa: {{this.visaSponsorship}}</div>
       <div>Contact: {{this.contactMethod}}</div>
        {{#if this.contactUrl}}<div>URL: {{this.contactUrl}}</div>{{/if}}
        {{#if this.contactEmail}}<div>Email: {{this.contactEmail}}</div>{{/if}}
      <p class="text-sm" style="white-space: pre-line;">{{this.fullDescription}}</p>
      <div>ID: {{this.id}} · Tier: {{this.tier}} · Created: {{this.createdAt}}</div>
    </div>
  {{else}}
    <p class="text-slate-500 text-sm p-4">No jobs in this session.</p>
  {{/each}}

  <div class="flex gap-2 p-4">
    <form method="POST" action="/admin/queue/{{session.id}}/approve">
      <button type="submit" class="font-mono tracking-wide border border-slate-200 hover:border-black py-1 px-3 uppercase text-sm">Approve</button>
    </form>
    <form method="POST" action="/admin/queue/{{session.id}}/reject">
      <button type="submit" class="font-mono tracking-wide border border-slate-200 hover:border-black py-1 px-3 uppercase text-sm">Reject</button>
    </form>
  </div>

</div>
