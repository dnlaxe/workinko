{{> admin-navbar}}

<div class="flex flex-col gap-4 p-4">
  <a href="/admin/queue" class="underline text-slate-700">← Back to queue</a>

  <div class="border border-slate-200">
    <div class="flex flex-row">
      <div class="w-8 border-r border-slate-200 bg-slate-100"></div>
      <div class="flex-1">
        <div class="border-b border-slate-200 px-4 py-2">
          <div class="underline">{{session.email}}</div>
        </div>
        <div class="px-4 py-2">
          <div class="flex flex-col text-slate-700">
            <span>ID: {{session.id}}</span>
            <span>Status: {{session.status}}</span>
            <span>Created: {{session.createdAt}}</span>
            <span>Updated: {{session.updatedAt}}</span>
            <span>Expires: {{session.expiresAt}}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  {{#each jobs}}
    <div class="border border-slate-200 rounded">
      <div class="flex flex-row">
        <div class="w-8 border-r border-slate-200 bg-slate-100"></div>
        <div class="flex-1">
          <div class="border-b border-slate-200 px-4 py-2">
            <div class="underline">{{this.heading}}</div>
            <div>{{this.subheading}}</div>
            <div>{{this.specialization}}</div>
          </div>
          <div class="border-b border-slate-200 px-4 py-2">
            <div class="flex flex-col text-slate-700">
              <span>{{this.startDate}}</span>
              <span>{{this.province}}, {{this.city}}</span>
              <span>{{this.contractType}}</span>
            </div>
          </div>
          <div class="border-b border-slate-200 px-4 py-2">
            <div class="flex flex-col text-slate-700">
              <span>Korean: {{proficiencyLabel this.koreanProficiency}}</span>
              <span>English: {{proficiencyLabel this.englishProficiency}}</span>
              {{#if this.otherLanguages}}<span>Other: {{this.otherLanguages}}</span>{{/if}}
              <span>Visa: {{this.visaSponsorship}}</span>
            </div>
          </div>
          <div class="border-b border-slate-200 px-4 py-2">
            <div class="flex flex-col text-slate-700">
              <span>Contact: {{this.contactMethod}}</span>
              {{#if this.contactUrl}}<span>URL: {{this.contactUrl}}</span>{{/if}}
              {{#if this.contactEmail}}<span>Email: {{this.contactEmail}}</span>{{/if}}
            </div>
          </div>
          <div class="px-4 py-2">
            <div class="flex flex-col text-slate-700">
              <span>ID: {{this.id}} · Tier: {{this.tier}}</span>
              <span>Created: {{this.createdAt}}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  {{else}}
    <p class="text-slate-500 text-sm p-4">No jobs in this session.</p>
  {{/each}}

  <div class="flex gap-4">
    <form method="POST" action="/admin/queue/{{session.id}}/approve">
      <button type="submit" class="rounded-full bg-green-500 text-white hover:bg-green-600 px-4 py-1">Approve</button>
    </form>
    <form method="POST" action="/admin/queue/{{session.id}}/reject">
      <button type="submit" class="rounded-full bg-slate-500 text-white px-4 py-1">Reject</button>
    </form>
  </div>
</div>
