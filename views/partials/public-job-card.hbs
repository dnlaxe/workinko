<div class="border border-slate-200 rounded">

  <div class="flex flex-row">

    <div class="w-8 border-r border-slate-200 bg-slate-100"></div>

    <div class="flex-1 md:flex">

      <div
        class="border-b border-slate-200 md:border-b-0 border-r px-4 py-2 md:flex-1"
      >
        <div>{{heading}}</div>
        <div>{{subheading}}</div>
        <div>{{specialization}}</div>
      </div>

      <div class="border-b border-slate-200 md:border-b-0 border-r px-4 py-2">

        <div class="flex flex-col text-slate-700 w-30">
          <span>{{startDate}}</span>
          <span>{{city}}</span>
          <span>{{contractType}}</span>
        </div>

      </div>
      <div class="flex px-4 py-2">
        <a
          href="/jobs/{{slug}}"
          class="text-blue-500 underline ml-auto md:mt-auto"
        >See details</a>
      </div>
    </div>

  </div>

</div>