<div class="border border-slate-200 rounded bg-white">

  <div>
    {{! <div class="flex flex-row"> }}

    {{! <div class="w-4 border-r border-slate-200 bg-slate-50 rounded-l-sm"></div> }}

    <div class="flex-1 md:flex p-4 md:px-8 md:py-4">

      <div class="md:border-b-0 md:flex-1 md:flex md:flex-col md:gap-4 md:mr-8">
        <div>{{heading}}</div>
        <div>{{subheading}}</div>

      </div>

      <div class="flex flex-col text-slate-700 w-30">
        <div>{{specialization}}</div>
        <span>{{startDate}}</span>
        <span>{{city}}</span>
        <span>{{contractType}}</span>
      </div>

      <div class="flex">
        <a
          href="/jobs/{{slug}}"
          class="text-blue-500 underline ml-auto md:mt-auto"
        >See details</a>
      </div>
    </div>

  </div>

</div>