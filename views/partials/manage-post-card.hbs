<div class="border border-slate-300">

  <div class="flex flex-row">

    <div class="w-8 border-r border-slate-300 bg-slate-100"></div>

    <div class="flex-1">

      <div class="border-b border-slate-300 px-4 py-2">
        <div class="underline">{{heading}}</div>
        <div>{{subheading}}</div>
      </div>

      <div class="border-b border-slate-300 px-4 py-2">
        <div class="flex flex-col text-slate-700">
          <span>{{startDate}}</span>
          <span>{{city}}</span>
          <span>{{contractType}}</span>
          <span>{{specialization}}</span>
        </div>
      </div>

      <div class="border-b border-slate-300 px-4 py-2">
        <div class="flex flex-col text-slate-700">
          <span>Korean: {{koreanProficiency}}</span>
          <span>English: {{englishProficiency}}</span>
          <span>Visa: {{visaSponsorship}}</span>
          <span>{{status}}</span>
          <span>Expires: {{expiresAt}}</span>
        </div>
      </div>

      <div class="flex px-4 py-2 gap-4">
        <a
          href="/manage/edit/{{id}}?token={{token}}"
          class="text-blue-500 underline"
        >Edit</a>
        <form method="POST" action="/manage/extend/{{id}}?token={{token}}">
          <button type="submit" class="text-blue-500 underline">Extend</button>
        </form>
        <form method="POST" action="/manage/delete/{{id}}?token={{token}}">
          <button type="submit" class="text-blue-500 underline">Delete</button>
        </form>
      </div>

    </div>

  </div>

</div>