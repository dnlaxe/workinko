<div class="max-w-3xl mx-auto w-full">
  <div class="p-4">
    <form method="POST" action="/jobs/drafts/checkout" class="flex flex-col gap-4">

      {{#if serverError}}
        <p class="text-slate-500 text-sm p-4">
          {{serverError}}
        </p>
      {{/if}}

      {{#if draftsError}}
        <p class="text-slate-500 text-sm p-4">Could not load drafts.</p>
      {{else}}
        {{#each drafts}}
          <div class="border border-slate-200 rounded">
            <div class="flex flex-row">
              <div class="w-8 border-r border-slate-200 bg-slate-100"></div>
              <div class="flex-1">
                <div class="flex flex-rows justify-between border-b border-slate-200 px-4 py-2">
                  <div>
                  <div>{{this.heading}}</div>
                  <div>{{this.subheading}}</div>
                  </div>
                    <button
                      type="submit"
                      class="text-red-500 underline"
                      formaction="/jobs/drafts/{{this.id}}/delete"
                      formmethod="POST"
                    >Delete</button>
                </div>
                <div class="px-4 pb-4">
                  <fieldset>
                    <p class="text-slate-500 my-2">Post type</p>
                    <div class="grid grid-cols-2 gap-4">
                      <label class="cursor-pointer group">
                        <input
                          type="radio"
                          name="{{this.id}}"
                          value="standard"
                          class="sr-only peer"
                          {{#if (eq this.tier "pinned")}}{{else}}checked{{/if}}
                        />
                        <span class="flex flex-col items-start px-3 py-2 rounded border border-slate-200 bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-slate-200">
                          <span class="text-lg">Standard</span>
                          <ul class="text-sm text-slate-600">
                            <li>Listed for thirty days</li>
                            <li>Management link</li>
                          </ul>
                          <span>Free</span>
                        </span>
                        
                      </label>
                      <label class="cursor-pointer group">
                        <input
                          type="radio"
                          name="{{this.id}}"
                          value="pinned"
                          class="sr-only peer"
                          {{#if (eq this.tier "pinned")}}checked{{/if}}
                        />
                        <span class="flex flex-col items-start px-3 py-2 rounded border border-slate-200 bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-slate-200">
                          <span class="text-lg">Pinned</span>
                          <ul class="text-sm text-slate-600">
                            <li>Pinned to the top of all listings</li>
                            <li>Pinned for thirty days</li>
                            <li>Link management</li>
                          </ul>
                          <span>$10</span>
                        </span>
                      </label>
                    </div>
                  </fieldset>
                </div>
              </div>
            </div>
          </div>
        {{else}}
          <p class="text-slate-500 p-4">No drafts yet.</p>
        {{/each}}
      {{/if}}

    <div class="bill border border-slate-200 rounded p-4">
      <p>Bill</p>
    </div>

    <div class="flex flex-row justify-between">
      <a href="/jobs/new" class="text-blue-500 underline">{{#unless drafts}}Add
          a job{{else}}Add another job{{/unless}}</a>

        <button
          type="submit"
          class="px-4 py-1 rounded-full bg-slate-500 text-white"
        >Submit posts</button>
      </form>
    </div>
  </div>
</div>

<script src="/calculate.js" defer></script>