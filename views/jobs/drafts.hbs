<div class="flex flex-col gap-4 p-4">
  {{#if draftsError}}
    <p class="text-slate-500 text-sm p-4">Could not load drafts.</p>
  {{else}}
    {{#each drafts}}
      <div class="border border-slate-300">
        <div class="flex flex-row">
          <div class="w-8 border-r border-slate-300 bg-slate-100"></div>
          <div class="flex-1">
            <div class="border-b border-slate-300 px-4 py-2">
              <div class="underline">{{this.heading}}</div>
            </div>
            <div class="flex px-4 py-2 gap-4">
              <form method="POST" action="/jobs/drafts/{{this.id}}/delete">
                <button
                  type="submit"
                  class="text-blue-500 underline"
                >Delete</button>
              </form>
              <a href="/jobs/new" class="text-blue-500 underline">Add another
                job</a>
            </div>
          </div>
        </div>
      </div>
    {{else}}
      <p class="text-slate-500 text-sm p-4">No drafts yet.</p>
    {{/each}}
  {{/if}}

  <div class="flex">
    <form method="POST" action="/jobs/drafts/submit" class="ml-auto">
      <button
        type="submit"
        class="px-4 py-1 rounded-full bg-slate-500 text-white"
      >Submit posts</button>
    </form>
  </div>
</div>