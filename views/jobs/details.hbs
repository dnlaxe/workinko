<div>
  <a
    href="/jobs/board"
    class="p-4 font-mono uppercase text-sm hover:cursor-pointer inline-flex items-center gap-2 tracking-wide"
  ><span class="block size-2 rounded-full bg-red-500/80"></span>Back to listings</a>

  <div class="mb-4 border-t border-slate-200">
    <div class="p-4">
      <div class="text-3xl font-black mb-4">{{heading}}</div>
      <div class="text-2xl">{{subheading}}</div>
    </div>

    <div class="md:flex p-4 border-y border-slate-200">
      <div class="md:flex-1 mb-2 md:mb-0">
        <div
          class="flex flex-col gap-2 font-mono uppercase text-sm tracking-wide"
        >
          <span><i class="ph ph-read-cv-logo mr-2"></i>{{specialization}}</span>
          <span><i class="ph ph-calendar-dot mr-2"></i>{{startDate}}</span>
          <span><i class="ph ph-map-pin-area mr-2"></i>{{province}},
            {{city}}</span>
          <span><i class="ph ph-hourglass-high mr-2"></i>{{contractType}}</span>
        </div>
      </div>

      <div class="md:flex-1">
        <div
          class="flex flex-col gap-2 font-mono uppercase text-sm tracking-wide"
        >
          <span><i class="ph ph-translate mr-2"></i>Korean:
            {{koreanProficiency}}</span>
          <span><i class="ph ph-translate mr-2"></i>English:
            {{englishProficiency}}</span>
          {{#if otherLanguages}}
            <span><i class="ph ph-translate mr-2"></i>Other:
              {{otherLanguages}}</span>
          {{/if}}
          <span><i class="ph ph-file-text mr-2"></i>Visa:
            {{visaSponsorship}}</span>
        </div>
      </div>
    </div>
  </div>

  {{! <div class="flex py-2">
    <a href="/" class="text-red-500 underline ml-auto text-sm">Report</a>
  </div> }}

  <div class="flex flex-col gap-4">

    <p
      style="white-space: pre-line;"
      class="p-4 wrap-break-word"
    >{{fullDescription}}</p>

  </div>

  <div class="flex flex-col gap-2 mt-4">
    {{#if isRelay}}
      <a
        href="/jobs/{{slug}}/contact"
        class="py-3 px-7 font-mono uppercase border text-center"
      >Contact poster</a>
    {{else}}
      <a
        href="{{contactUrl}}"
        class="py-3 px-7 font-mono uppercase border text-center"
      >Apply here</a>
    {{/if}}
  </div>

  {{#if isRelay}}
    <a
      href="/jobs/{{slug}}/contact"
      class="md:hidden fixed right-0 top-1/2 -translate-y-1/2 p-4 bg-red-500/80 text-white font-mono uppercase text-sm flex font-semibold flex-col items-center"
    >C<br />O<br />N<br />T<br />A<br />C<br />T</a>
  {{else}}
    <a
      href="{{contactUrl}}"
      class="md:hidden fixed right-0 top-1/2 -translate-y-1/2 p-4 bg-red-500/80 text-white font-mono uppercase text-sm font-semibold flex flex-col items-center"
    >A<br />P<br />P<br />L<br />Y</a>
  {{/if}}

</div>