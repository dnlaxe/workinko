<div class="p-4">
  <a href="/jobs/{{slug}}" class="underline text-slate-700">Back to listing</a>
  <form
    method="POST"
    action="/jobs/{{slug}}/contact"
    class="border border-slate-200 rounded mt-4"
  >
    {{#if serverError}}
      <div class="border-b border-slate-200 px-4 py-2">
        <p class="text-slate-500 text-sm">{{serverError}}</p>
      </div>
    {{/if}}

    <input type="hidden" name="slug" value="{{slug}}" />
    <input type="hidden" name="heading" value="{{heading}}" />

    <div class="border-b border-slate-200 px-4 py-2">
      <label class="block" for="email">Your email</label>
      <input
        class="block w-full px-3 py-2 rounded border border-slate-200 bg-white text-slate-600"
        type="email"
        id="email"
        name="email"
        value="{{values.email}}"
        required
      />
      {{#if fieldErrors.email}}<p class="text-slate-500 text-sm">{{fieldErrors.email}}</p>{{/if}}
    </div>

    <div class="border-b border-slate-200 px-4 py-2">
      <label class="block" for="message">Message</label>
      <textarea
        class="block w-full px-3 py-2 rounded border border-slate-200 bg-white text-slate-600 resize-none"
        id="message"
        name="message"
        required
      >{{values.message}}</textarea>
      {{#if fieldErrors.message}}<p class="text-slate-500 text-sm">{{fieldErrors.message}}</p>{{/if}}
    </div>

    <div class="flex px-4 py-2">
      <button
        type="submit"
        class="rounded-full bg-slate-500 text-white px-4 py-1 ml-auto"
      >Send</button>
    </div>
  </form>
</div>
