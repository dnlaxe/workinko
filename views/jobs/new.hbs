{{#if fieldErrors}}
<script class="js-has-errors" type="application/json">{{{json fieldErrors}}}</script>
{{/if}}

<form action="/jobs/new" method="POST" data-specializations='{{{specializationsByCategory}}}' data-cities='{{{citiesByProvince}}}' class="px-4 md:mx-0 pb-4 md:h-dvh">
<div class="sessionEmail" hidden>{{sessionEmail}}</div>

  <div class="mb-8 mt-4" aria-label="Form progress">
    <div class="flex">
      <span data-progress-index="0" class="flex-1 h-2 bg-slate-200 transition duration-500"></span>
      <span data-progress-index="1" class="flex-1 h-2 bg-slate-200 transition duration-500"></span>
      <span data-progress-index="2" class="flex-1 h-2 bg-slate-200 transition duration-500"></span>
      <span data-progress-index="3" class="flex-1 h-2 bg-slate-200 transition duration-500"></span>
      <span data-progress-index="4" class="flex-1 h-2 bg-slate-200 transition duration-500"></span>
      <span data-progress-index="5" class="flex-1 h-2 bg-slate-200"></span>
      <span data-progress-index="6" class="flex-1 h-2 bg-slate-200"></span>
      <span data-progress-index="7" class="flex-1 h-2 bg-slate-200"></span>
      <span data-progress-index="8" class="flex-1 h-2 bg-slate-200"></span>
      <span data-progress-index="9" class="flex-1 h-2 bg-slate-200"></span>
      <span data-progress-index="10" class="flex-1 h-2 bg-slate-200"></span>
      <span data-progress-index="11" class="flex-1 h-2 bg-slate-200"></span>
    </div>
  </div>

  <div class="step flex-1">
    <fieldset>
      <div>
        <div class="flex items-center gap-3 mb-8">
          <button
            type="button"
            class="btn-back text-xl inline-flex items-center justify-center leading-none shrink-0"
          ></button>
          <p class="text-2xl">How do you want to be contacted?</p>
        </div>

        <label class="block cursor-pointer mb-2">
          <input
            type="radio"
            name="contactMethod"
            value="relay"
            {{#if (eq values.contactMethod "relay")}}checked{{/if}}
            class="sr-only peer"
          />
          <div class="p-4 border border-slate-200 peer-checked:border-black hover:border-black">
            <p>Via email</p>
            <p>We'll use your email: <strong>{{sessionEmail}}</strong></p>
            <p>This will not be publicly visible.</p>
          </div>
        </label>

        <label class="block cursor-pointer mb-2">
          <input
            type="radio"
            name="contactMethod"
            value="link"
            {{#if (eq values.contactMethod "link")}}checked{{/if}}
            class="sr-only peer"
          />
          <div class="p-4 border border-slate-200 peer-checked:border-black hover:border-black">
            <p>Via a link</p>
            <label for="contactUrl">Your link</label>
            <input
              id="contactUrl"
              name="contactUrl"
              type="url"
              value="{{values.contactUrl}}"
              class="block w-full px-3 py-2 bg-white border border-slate-200 mt-1"
            />
            <button type="button" data-step-inline-next>Next</button>
          </div>
        </label>

      </div>
    </fieldset>
</div>

{{> job-form-radio-step
  title="Is this a teaching or non-teaching job?"
  name="category"
  options=jobFormOptions.category
  selectedValue=values.category
}}

{{> job-form-radio-step
  title="Job position"
  name="specialization"
  options=jobFormOptions.specialization
  selectedValue=values.specialization
}}

{{> job-form-radio-step
  title="Province"
  name="province"
  options=jobFormOptions.province
  selectedValue=values.province
}}

{{> job-form-radio-step
  title="Nearest city"
  name="city"
  options=jobFormOptions.city
  selectedValue=values.city
}}

{{> job-form-radio-step
  title="Korean proficiency"
  name="koreanProficiency"
  options=jobFormOptions.koreanProficiency
  selectedValue=values.koreanProficiency
}}


{{> job-form-radio-step
  title="English proficiency"
  name="englishProficiency"
  options=jobFormOptions.englishProficiency
  selectedValue=values.englishProficiency
}}

<div class="step flex-1" hidden>
    <div>
        <div class="flex items-center gap-3 mb-8">
          <button
            type="button"
            class="btn-back text-xl inline-flex items-center justify-center leading-none shrink-0"
          ><i class="ph ph-arrow-left"></i></button>
          <p class="text-2xl">Other languages</p>
        </div>

      <label class="block cursor-pointer mb-2">
        <input type="radio" name="otherLanguagesMode" value="notRequired" class="sr-only peer" />
        <span class="flex items-center px-3 py-2 border border-slate-200 peer-checked:border-black hover:border-[#0D0D0D]">
          Not required
        </span>
      </label>

      <label class="block cursor-pointer">
        <input
          type="radio"
          name="otherLanguagesMode"
          value="provided"
          {{#if values.otherLanguages}}checked{{/if}}
          class="sr-only peer"
        />
        <div class="p-4 border border-slate-200 peer-checked:border-black hover:border-black">
          <span class="block">Other language:</span>
          <input
            id="otherLanguages"
            name="otherLanguages"
            type="text"
            value="{{values.otherLanguages}}"
            class="block w-full px-3 py-2 border border-slate-200 mt-1"
          />
          <button type="button" data-step-inline-next>Next</button>
        </div>
      </label>

  </div>
</div>

{{> job-form-radio-step
  title="Contract type"
  name="contractType"
  options=jobFormOptions.contractType
  selectedValue=values.contractType
}}

{{> job-form-radio-step
  title="Visa sponsorship"
  name="visaSponsorship"
  options=jobFormOptions.visaSponsorship
  selectedValue=values.visaSponsorship
}}

{{> job-form-radio-step
  title="Start date"
  name="startDate"
  options=jobFormOptions.startDate
  selectedValue=values.startDate
}}

    <div class="step flex-1" hidden>
        <div>
          <div class="flex items-center gap-3 mb-2">
            <button type="button" class="btn-back text-xl inline-flex items-center justify-center leading-none shrink-0"><i class="ph ph-arrow-left"></i></button>
            <label class="text-2xl">Jod description</label>
          </div>
          <label for="heading">Title</label>
          <input
            id="heading"
            name="heading"
            type="text"
            class="block w-full px-3 py-2  border border-[#CBCCCE] mb-2"
            value="{{values.heading}}"
          />

          <label class="block" for="subheading">Second line</label>
          <input
            id="subheading"
            name="subheading"
            type="text"
            class="block w-full px-3 py-2  border border-[#CBCCCE] mb-2"
            value="{{values.subheading}}"
          />

          <label for="fullDescription">Detailed description</label>
          <textarea
            class="block w-full h-[40%] px-3 py-2  border border-[#CBCCCE] resize-none"
            id="fullDescription"
            name="fullDescription"
          >{{values.fullDescription}}</textarea>
          <button type="button" class="btn-last-next disabled:opacity-50 px-3 py-1 border border-slate-200 uppercase tracking-wide hover:border-black mt-8">Next</button>
        </div>
    </div>

  <div class="review step" hidden>
    <button type="submit" class="btn-confirm inline-block tracking-wide border border-slate-200 py-1 px-3 font-mono uppercase hover:border-black">Confirm</button>
  </div>

  <button type="button" class="btn-back-to-review border font-mono tracking-wide uppercase mt-4 py-1 px-4" hidden>Back to review</button>

</form>

<script type="module" src="/js/form.js"></script>