

<div class="max-w-2xl mx-auto w-full md:mt-4 md:rounded flex flex-col">

<form action="/jobs/new" method="POST" {{#if fieldErrors}}data-has-errors{{/if}} {{#if serverError}}data-has-errors{{/if}} class="p-8 flex flex-col flex-1">

{{#if serverError}}
  <p>{{serverError}}</p>
{{/if}}

  <div class="mb-2" aria-label="Form progress">
    <p class="step-counter text-xs mb-2">Step 1 of 7</p>
    <div class="flex gap-1">
      <span
        data-progress-index="0"
        class="flex-1 h-2 rounded-full bg-slate-200 transition-colors duration-300"
      ></span>
      <span
        data-progress-index="1"
        class="flex-1 h-2 rounded-full bg-slate-200 transition-colors duration-300"
      ></span>
      <span
        data-progress-index="2"
        class="flex-1 h-2 rounded-full bg-slate-200 transition-colors duration-300"
      ></span>
      <span
        data-progress-index="3"
        class="flex-1 h-2 rounded-full bg-slate-200 transition-colors duration-300"
      ></span>
      <span
        data-progress-index="4"
        class="flex-1 h-2 rounded-full bg-slate-200 transition-colors duration-300"
      ></span>
      <span
        data-progress-index="5"
        class="flex-1 h-2 rounded-full bg-slate-200 transition-colors duration-300"
      ></span>
      <span
        data-progress-index="6"
        class="flex-1 h-2 rounded-full bg-slate-200 transition-colors duration-300"
      ></span>
    </div>
  </div>

  <div class="step flex-1">
    <div class="step__content">
      <fieldset>
        <h1 class="text-xs uppercase tracking-widest mb-8">Contact details</h1>
        <p class="mb-2">How do you want to be contacted?</p>

        {{#each jobFormOptions.contactMethod}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="contactMethod"
              value="{{this}}"
              required
              {{#if (eq ../values.contactMethod this)}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE]  transition-all peer-checked:bg-black peer-checked:text-white peer-checked:border-black group-hover:">
              {{#if (eq this "link")}}Via a link{{else}}Via email{{/if}}

            </span>
          </label>
        {{/each}}

        {{#if fieldErrors.contactMethod}}
          <div data-error="contactMethod">{{fieldErrors.contactMethod.[0]}}</div>
        {{/if}}

        <div
          data-contact-field="link"
          class="mt-4"
          {{#unless (eq values.contactMethod "link")}}hidden{{/unless}}
        >
          <label class="block" for="contactUrl">Please give your link.</label>
          <p>Link advice</p>
          <input
            id="contactUrl"
            name="contactUrl"
            type="url"
            value="{{values.contactUrl}}"
            class="block w-full px-3 py-2 rounded border border-[#CBCCCE]   "
          />
          {{#if fieldErrors.contactUrl}}
            <div data-error="contactUrl">{{fieldErrors.contactUrl.[0]}}</div>
          {{/if}}
        </div>

        <div
          data-contact-field="relay"
          class="mt-4"
          {{#unless (eq values.contactMethod "relay")}}hidden{{/unless}}
        >
          <p>We'll use your email: <strong>{{sessionEmail}}</strong></p>
          <p>This will not be publicly visible.</p>
        </div>
      </fieldset>
    </div>
  </div>

  <div class="step flex-1" hidden>
    <div class="step__content [&:has(input[name='category']:checked)_.select-tag-hint]:block">
      <fieldset>
        <h1 class="text-xs uppercase tracking-widest mb-8">Job details</h1>
        <p class="mb-2">Is this a teaching or non-teaching job?</p>

        <div class="grid grid-cols-2 gap-1">
          {{#each jobFormOptions.category}}
            <label class="block mb-1.5 cursor-pointer group">
              <input
                type="radio"
                name="category"
                value="{{this}}"
                required
                {{#if (eq ../values.category this)}}checked{{/if}}
                class="sr-only peer"
              />
              <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE]    transition-all peer-checked:bg-black peer-checked:text-white peer-checked:border-black group-hover:">
                {{this}}
              </span>
            </label>
          {{/each}}
        </div>
      </fieldset>

      <div class="select-tag-hint hidden">
        <p class="mt-4 mb-2">Select a tag</p>
      </div>

      <div class="grid grid-cols-2 gap-1">
        {{#each jobFormOptions.specialization}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="specialization"
              value="{{this}}"
              required
              {{#if (eq ../values.specialization this)}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE]    transition-all peer-checked:bg-black peer-checked:text-white peer-checked:border-black group-hover:">
              {{this}}
            </span>
          </label>
        {{/each}}
      </div>
    </div>
  </div>

<div class="step flex-1" hidden>
  <div class="step__content [&:has(input[name='province']:checked)_.select-tag-hint]:block">
    <fieldset>
      <h1 class="text-xs uppercase tracking-widest mb-8">Location</h1>
      <p class="mb-2">Province</p>

      <div class="grid grid-cols-2 gap-1">
        {{#each jobFormOptions.province}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="province"
              value="{{this}}"
              required
              {{#if (eq ../values.province this)}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE]    transition-all peer-checked:bg-black peer-checked:text-white peer-checked:border-black group-hover:">
              {{this}}
            </span>
          </label>
        {{/each}}
      </div>
    </fieldset>

    <div class="select-tag-hint hidden">
      <p class="mt-4 mb-2">Select the nearest city</p>
    </div>

    <div class="grid grid-cols-2 gap-1">
      {{#each jobFormOptions.city}}
        <label class="block mb-1.5 cursor-pointer group">
          <input
            type="radio"
            name="city"
            value="{{this}}"
            required
            {{#if (eq ../values.city this)}}checked{{/if}}
            class="sr-only peer"
          />
          <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE]    transition-all peer-checked:bg-black peer-checked:text-white peer-checked:border-black group-hover:">
            {{this}}
          </span>
        </label>
      {{/each}}
    </div>
  </div>
</div>

  <div class="step flex-1" hidden>
    <div class="step__content">
      <fieldset>
        <h1 class="text-xs uppercase tracking-widest mb-8">Language proficiency</h1>
        <p class="mb-2">Korean proficiency</p>

        <div class="grid grid-cols-2 gap-1">
          {{#each jobFormOptions.koreanProficiency}}
            <label class="block mb-1.5 cursor-pointer group">
              <input
                type="radio"
                name="koreanProficiency"
                value="{{value}}"
                required
                {{#if (eq (toString ../values.koreanProficiency) (toString value))}}checked{{/if}}
                class="sr-only peer"
              />
              <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE]    transition-all peer-checked:bg-black peer-checked:text-white peer-checked:border-black group-hover:">
                {{label}}
              </span>
            </label>
          {{/each}}
        </div>
      </fieldset>

      <fieldset>
        <p class="mb-2 mt-4">English proficiency</p>

        <div class="grid grid-cols-2 gap-1">
          {{#each jobFormOptions.englishProficiency}}
            <label class="block mb-1.5 cursor-pointer group">
              <input
                type="radio"
                name="englishProficiency"
                value="{{value}}"
                required
                {{#if (eq (toString ../values.englishProficiency) (toString value))}}checked{{/if}}
                class="sr-only peer"
              />
              <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE]    transition-all peer-checked:bg-black peer-checked:text-white peer-checked:border-black group-hover:">
                {{label}}
              </span>
            </label>
          {{/each}}
        </div>
      </fieldset>

      <div class="mt-4">
        <label class="block" for="otherLanguages">Other languages</label>
        <input
          id="otherLanguages"
          name="otherLanguages"
          type="text"
          class="block w-full px-3 py-2 rounded border border-[#CBCCCE]    mt-2"
          value="{{values.otherLanguages}}"
        />
        {{#if fieldErrors.otherLanguages}}
          <div data-error="otherLanguages">{{fieldErrors.otherLanguages.[0]}}</div>
        {{/if}}
      </div>
    </div>
  </div>

  <div class="step flex-1" hidden>
    <div class="step__content">
      <fieldset>
        <h1 class="text-xs uppercase tracking-widest mb-8">Contract </h1>
        <p class="mb-2">Type</p>

        {{#each jobFormOptions.contractType}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="contractType"
              value="{{this}}"
              required
              {{#if (eq ../values.contractType this)}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE]    transition-all peer-checked:bg-black peer-checked:text-white peer-checked:border-black group-hover:">
              {{this}}
            </span>
          </label>
        {{/each}}
      </fieldset>

      <fieldset>
        <p class="mb-2 mt-4">Visa sponsorship</p>

        {{#each jobFormOptions.visaSponsorship}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="visaSponsorship"
              value="{{this}}"
              required
              {{#if (eq ../values.visaSponsorship this)}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE]    transition-all peer-checked:bg-black peer-checked:text-white peer-checked:border-black group-hover:">
              {{this}}
            </span>
          </label>
        {{/each}}
      </fieldset>
    </div>
  </div>

  <div class="step flex-1" hidden>
    <div class="step__content">
      <fieldset>
        <h1 class="text-xs uppercase tracking-widest mb-8">Start date</h1>
        <p class="mb-2">When does this position begin?</p>

        <div class="grid grid-cols-2 gap-1">
          {{#each jobFormOptions.startDate}}
            <label class="block mb-1.5 cursor-pointer group">
              <input
                type="radio"
                name="startDate"
                value="{{this}}"
                required
                {{#if (eq ../values.startDate this)}}checked{{/if}}
                class="sr-only peer"
              />
              <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE]    transition-all peer-checked:bg-black peer-checked:text-white peer-checked:border-black group-hover:">
                {{this}}
              </span>
            </label>
          {{/each}}
        </div>
      </fieldset>
    </div>
  </div>

  <div class="step flex-1" hidden>
    <div class="step__content">
      <div>
        <h1 class="text-xs uppercase tracking-widest mb-8">Job description</h1>
        <label class="block" for="heading">Heading</label>
        <input
          id="heading"
          name="heading"
          type="text"
          class="block w-full px-3 py-2 rounded border border-[#CBCCCE]    mb-2"
          required
          value="{{values.heading}}"
        />
        {{#if fieldErrors.heading}}
          <div data-error="heading">{{fieldErrors.heading.[0]}}</div>
        {{/if}}
      </div>

      <div>
        <label class="block" for="subheading">Subheading</label>
        <input
          id="subheading"
          name="subheading"
          type="text"
          class="block w-full px-3 py-2 rounded border border-[#CBCCCE]    mb-2"
          required
          value="{{values.subheading}}"
        />
        {{#if fieldErrors.subheading}}
          <div data-error="subheading">{{fieldErrors.subheading.[0]}}</div>
        {{/if}}
      </div>

      <div>
        <label class="block" for="fullDescription">Full description</label>
        <textarea
          class="block w-full h-[40%] px-3 py-2 rounded border border-[#CBCCCE]    resize-none"
          id="fullDescription"
          name="fullDescription"
          required
        >{{values.fullDescription}}</textarea>
        {{#if fieldErrors.fullDescription}}
          <div data-error="fullDescription">{{fieldErrors.fullDescription.[0]}}</div>
        {{/if}}
      </div>
    </div>
  </div>

  <nav class="step__nav flex flex-rows mt-8 justify-between gap-4">
    <button type="button" class="btn-back disabled:opacity-0 underline">Back</button>
    <button type="button" class="btn-next disabled:opacity-0 px-4 py-1 rounded border border-[#CBCCCE] w-full transition-opacity duration-200 uppercase tracking-wide">Next</button>
    <button type="button" class="btn-last-next disabled:opacity-50 px-4 py-1 rounded border border-[#CBCCCE] w-full transition-opacity duration-200 uppercase tracking-wide">Next</button>
    <button type="button" class="btn-back-to-review disabled:opacity-50 ml-auto px-4 py-1 w-full rounded border border-[#CBCCCE] uppercase tracking-wide" hidden>Back to review</button>
  </nav>


  <div class="review" hidden>
    <div class="flex flex-rows justify-end px-2 mt-4">
      <button type="submit" class="btn-confirm px-4 py-1 rounded w-full border border-[#CBCCCE]">Confirm</button>
    </div>
  </div>

</form>

</div>

<script src="/new.js" defer></script>
<script src="/options.js" defer></script>
