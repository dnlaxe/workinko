<div class="md:flex md:border border-slate-200 md:rounded">

  <div class="md:w-60 md:shrink-0">
    <div class="text-slate-700 bg-blue-300 px-8 py-2 md:p-4 md:rounded-tl-sm">A job board for opportunities in Korea</div>
    <div class="md:border-b text-white bg-slate-700 px-8 py-2 md:p-4">Last updated: Jan 26</div>
    <div class="flex justify-end p-4 md:hidden">
      <button class="filterBtn px-4 py-1 rounded-full border border-slate-200">Filter</button>
    </div>
    <form method="GET" action="/jobs/board" class="filter max-h-0 overflow-hidden md:max-h-none md:flex md:flex-col">
      <div class="px-2 py-0 flex flex-wrap gap-2 md:flex-col md:border-b border-slate-200 md:py-2 md:px-0">
        {{#each categories}}
          <label class="block cursor-pointer group">
            <input type="checkbox" name="category" value="{{this}}" class="sr-only peer" {{#if (contains ../activeCategory this)}}checked{{/if}}>
            <span class="flex px-4 py-1 bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-slate-300">{{this}}</span>
          </label>
        {{/each}}
      </div>
      <div class="px-2 py-2 flex flex-wrap md:flex-col gap-2 md:border-b border-slate-200 md:py-2 md:px-0">
        {{#each provinces}}
          <label class="block cursor-pointer group">
            <input type="checkbox" name="province" value="{{this}}" class="sr-only peer" {{#if (contains ../activeProvince this)}}checked{{/if}}>
            <span class="flex px-4 py-1 bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-slate-300">{{this}}</span>
          </label>
        {{/each}}
      </div>
      <div class="px-4 py-4 md:px-2 flex justify-between">
        <button type="submit" class="px-4 py-1 rounded-full bg-blue-300 border border-blue-400 text-slate-700">Apply</button>
        <a href="/jobs/board" class="px-4 py-1 rounded-full text-slate-900 bg-white underline decoration-slate-900">Reset</a>
      </div>
    </form>
  </div>

  <div class="flex-1 flex flex-col gap-4 p-4 border-t md:border-t-0 md:border-l border-slate-200">
    {{#if boardError}}
      <p class="text-slate-500 text-sm p-4">Something went wrong loading posts.</p>
    {{else if posts}}
      {{#each posts}}
        {{> public-job-card this}}
      {{/each}}
    {{else}}
      <p class="text-slate-500 p-4 pb-0">No live posts yet.</p><a href="/jobs/board" class="px-4 rounded-full text-slate-900 bg-white underline decoration-slate-900">Reset</a>
    {{/if}}
  </div>

</div>

<script src="/filter.js" defer></script>
