<form action="/manage/edit/{{id}}?token={{token}}" method="POST" {{#if fieldErrors}}data-has-errors{{/if}} {{#if serverError}}data-has-errors{{/if}} class="p-8">

  <a href="/manage?token={{token}}" class="mb-4 inline-block underline text-slate-700">Back to current posts</a>

{{#if serverError}}
  <p>{{serverError}}</p>
{{/if}}

  <div class="step">
    <div class="step__content">
      <fieldset>
        <legend>How do you want to be contacted?</legend>

        {{#each jobFormOptions.contactMethod}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="contactMethod"
              value="{{this}}"
              required
              {{#if (eq ../values.contactMethod this)}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-[#CBCCCE]">
              {{#if (eq this "link")}}Via a link{{else}}Via email{{/if}}
            </span>
          </label>
        {{/each}}

        {{#if fieldErrors.contactMethod}}
          <div data-error="contactMethod">{{fieldErrors.contactMethod.[0]}}</div>
        {{/if}}

        <div
          data-contact-field="link"
          {{#unless (eq values.contactMethod "link")}}hidden{{/unless}}
        >
          <label class="block" for="contactUrl">URL</label>
          <input
            id="contactUrl"
            name="contactUrl"
            type="url"
            value="{{values.contactUrl}}"
            class="block w-full px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600"
          />
          {{#if fieldErrors.contactUrl}}
            <div data-error="contactUrl">{{fieldErrors.contactUrl.[0]}}</div>
          {{/if}}
        </div>

        <div
          data-contact-field="relay"
          {{#unless (eq values.contactMethod "relay")}}hidden{{/unless}}
        >
          <p>We'll use your email: <strong>{{values.contactEmail}}</strong></p>
        </div>
      </fieldset>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content [&:has(input[name='category']:checked)_.select-tag-hint]:block">
      <fieldset>
        <legend>Category</legend>

        {{#each jobFormOptions.category}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="category"
              value="{{this}}"
              required
              {{#if (eq ../values.category this)}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-[#CBCCCE]">
              {{this}}
            </span>
          </label>
        {{/each}}
      </fieldset>

      <div class="select-tag-hint hidden">
        <p>Select a specialization</p>
      </div>

      {{#each jobFormOptions.specialization}}
        <label class="block mb-1.5 cursor-pointer group">
          <input
            type="radio"
            name="specialization"
            value="{{this}}"
            required
            {{#if (eq ../values.specialization this)}}checked{{/if}}
            class="sr-only peer"
          />
          <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-[#CBCCCE]">
            {{this}}
          </span>
        </label>
      {{/each}}
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content [&:has(input[name='province']:checked)_.select-tag-hint]:block">
      <fieldset>
        <legend>Province</legend>

        {{#each jobFormOptions.province}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="province"
              value="{{this}}"
              required
              {{#if (eq ../values.province this)}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-[#CBCCCE]">
              {{this}}
            </span>
          </label>
        {{/each}}
      </fieldset>

      <div class="select-tag-hint hidden">
        <p>Select the nearest city</p>
      </div>

      {{#each jobFormOptions.city}}
        <label class="block mb-1.5 cursor-pointer group">
          <input
            type="radio"
            name="city"
            value="{{this}}"
            required
            {{#if (eq ../values.city this)}}checked{{/if}}
            class="sr-only peer"
          />
          <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-[#CBCCCE]">
            {{this}}
          </span>
        </label>
      {{/each}}
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <fieldset>
        <legend>Korean proficiency</legend>

        {{#each jobFormOptions.koreanProficiency}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="koreanProficiency"
              value="{{value}}"
              required
              {{#if (eq (toString ../values.koreanProficiency) (toString value))}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-[#CBCCCE]">
              {{label}}
            </span>
          </label>
        {{/each}}
      </fieldset>

      <fieldset>
        <legend>English proficiency</legend>

        {{#each jobFormOptions.englishProficiency}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="englishProficiency"
              value="{{value}}"
              required
              {{#if (eq (toString ../values.englishProficiency) (toString value))}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-[#CBCCCE]">
              {{label}}
            </span>
          </label>
        {{/each}}
      </fieldset>

      <div>
        <label class="block" for="otherLanguages">Other languages</label>
        <input
          id="otherLanguages"
          name="otherLanguages"
          type="text"
          class="block w-full px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600"
          value="{{values.otherLanguages}}"
        />
        {{#if fieldErrors.otherLanguages}}
          <div data-error="otherLanguages">{{fieldErrors.otherLanguages.[0]}}</div>
        {{/if}}
      </div>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <fieldset>
        <legend>Contract type</legend>

        {{#each jobFormOptions.contractType}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="contractType"
              value="{{this}}"
              required
              {{#if (eq ../values.contractType this)}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-[#CBCCCE]">
              {{this}}
            </span>
          </label>
        {{/each}}
      </fieldset>

      <fieldset>
        <legend>Visa sponsorship</legend>

        {{#each jobFormOptions.visaSponsorship}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="visaSponsorship"
              value="{{this}}"
              required
              {{#if (eq ../values.visaSponsorship this)}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-[#CBCCCE]">
              {{this}}
            </span>
          </label>
        {{/each}}
      </fieldset>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <fieldset>
        <legend>Start date</legend>

        {{#each jobFormOptions.startDate}}
          <label class="block mb-1.5 cursor-pointer group">
            <input
              type="radio"
              name="startDate"
              value="{{this}}"
              required
              {{#if (eq ../values.startDate this)}}checked{{/if}}
              class="sr-only peer"
            />
            <span class="flex items-center px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600 transition-all peer-checked:border-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 group-hover:border-[#CBCCCE]">
              {{this}}
            </span>
          </label>
        {{/each}}
      </fieldset>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <div>
        <label class="block" for="heading">Heading</label>
        <input
          id="heading"
          name="heading"
          type="text"
          class="block w-full px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600"
          required
          value="{{values.heading}}"
        />
        {{#if fieldErrors.heading}}
          <div data-error="heading">{{fieldErrors.heading.[0]}}</div>
        {{/if}}
      </div>

      <div>
        <label class="block" for="subheading">Subheading</label>
        <input
          id="subheading"
          name="subheading"
          type="text"
          class="block w-full px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600"
          required
          value="{{values.subheading}}"
        />
        {{#if fieldErrors.subheading}}
          <div data-error="subheading">{{fieldErrors.subheading.[0]}}</div>
        {{/if}}
      </div>

      <div>
        <label class="block" for="fullDescription">Full description</label>
        <textarea
          class="block w-full h-[40%] px-3 py-2 rounded border border-[#CBCCCE] bg-white text-slate-600 resize-none"
          id="fullDescription"
          name="fullDescription"
          required
        >{{values.fullDescription}}</textarea>
        {{#if fieldErrors.fullDescription}}
          <div data-error="fullDescription">{{fieldErrors.fullDescription.[0]}}</div>
        {{/if}}
      </div>
    </div>
  </div>

  <nav class="step__nav flex flex-rows mt-8">
    <button type="button" class="btn-back-to-review disabled:opacity-50 ml-auto rounded-full bg-slate-500 text-white px-4 py-1" hidden>Apply changes</button>
  </nav>

  <div class="review" hidden>
    <div class="flex flex-rows justify-end space-x-8 px-4">
      <button type="submit" class="btn-confirm rounded-full bg-green-500 text-white hover:bg-green-600 px-4 py-1">Save Changes</button>
    </div>
  </div>

</form>

<script src="/edit.js" defer></script>
