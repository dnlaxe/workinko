{{! views/manage/edit.hbs }}
<form action="/manage/edit/{{postId}}?token={{token}}" method="POST" {{#if fieldErrors}}data-has-errors{{/if}} {{#if serverError}}data-has-errors{{/if}}>

{{#if serverError}}
  <p>{{serverError}}</p>
{{/if}}

  <div class="step">
    <div class="step__content">
      <fieldset>
        <legend>How do you want to be contacted?</legend>

        {{#each jobFormOptions.contactMethod}}
          <label class="flex items-center gap-3 px-4 py-3 border-2 border-[#e0e0e0] mb-2 cursor-pointer hover:border-[#0a0a0a] transition-colors duration-75 text-base has-checked:border-[#0a0a0a]">
            <input
              type="radio"
              name="contactMethod"
              value="{{this}}"
              class="w-5 h-5 cursor-pointer accent-[#0f62fe]"
              required
              {{#if (eq ../values.contactMethod this)}}checked{{/if}}
            />
            {{this}}
          </label>
        {{/each}}

        {{#if fieldErrors.contactMethod}}
          <div data-error="contactMethod">{{fieldErrors.contactMethod.[0]}}</div>
        {{/if}}

        <div
          data-contact-field="link"
          {{#unless (eq values.contactMethod "link")}}hidden{{/unless}}
        >
          <label for="contactUrl">URL</label>
          <input
            id="contactUrl"
            name="contactUrl"
            type="url"
            class="text-[19px] px-3 py-2 border-2 border-[#393939] bg-white text-[#0a0a0a] leading-relaxed appearance-none rounded-none placeholder:text-[#a8a8a8] focus:outline-none"
            value="{{values.contactUrl}}"
          />
          {{#if fieldErrors.contactUrl}}
            <div data-error="contactUrl">{{fieldErrors.contactUrl.[0]}}</div>
          {{/if}}
        </div>

        <div
          data-contact-field="relay"
          {{#unless (eq values.contactMethod "relay")}}hidden{{/unless}}
        >
          <p>We'll use your email: <strong>{{values.contactEmail}}</strong></p>
        </div>
      </fieldset>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <div>
        <label for="heading">Heading</label>
        <input
          id="heading"
          name="heading"
          type="text"
          class="text-[19px] px-3 py-2 border-2 border-[#393939] bg-white text-[#0a0a0a] leading-relaxed appearance-none rounded-none placeholder:text-[#a8a8a8] focus:outline-none"
          required
          value="{{values.heading}}"
        />
        {{#if fieldErrors.heading}}
          <div data-error="heading">{{fieldErrors.heading.[0]}}</div>
        {{/if}}
      </div>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <div>
        <label for="subheading">Subheading</label>
        <input
          id="subheading"
          name="subheading"
          type="text"
          class="text-[19px] px-3 py-2 border-2 border-[#393939] bg-white text-[#0a0a0a] leading-relaxed appearance-none rounded-none placeholder:text-[#a8a8a8] focus:outline-none"
          required
          value="{{values.subheading}}"
        />
        {{#if fieldErrors.subheading}}
          <div data-error="subheading">{{fieldErrors.subheading.[0]}}</div>
        {{/if}}
      </div>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <fieldset>
        <legend>Category</legend>

        {{#each jobFormOptions.category}}
          <label class="m-4 flex items-center gap-3 px-4 py-3 border-2 border-[#e0e0e0] mb-2 cursor-pointer hover:border-[#0a0a0a] transition-colors duration-75 text-base has-checked:border-[#0a0a0a]">
            <input
              type="radio"
              name="category"
              class="w-5 h-5 cursor-pointer accent-[#0f62fe]"
              value="{{this}}"
              required
              {{#if (eq ../values.category this)}}checked{{/if}}
            />
            {{this}}
          </label>
        {{/each}}
      </fieldset>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <fieldset>
        <legend>Specialization</legend>

        {{#each jobFormOptions.specialization}}
          <label class="flex items-center gap-3 px-4 py-3 border-2 border-[#e0e0e0] mb-2 cursor-pointer hover:border-[#0a0a0a] transition-colors duration-75 text-base has-checked:border-[#0a0a0a]">
            <input
              type="radio"
              name="specialization"
              value="{{this}}"
              class="w-5 h-5 cursor-pointer accent-[#0f62fe]"
              required
              {{#if (eq ../values.specialization this)}}checked{{/if}}
            />
            {{this}}
          </label>
        {{/each}}
      </fieldset>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <fieldset>
        <legend>Contract type</legend>

        {{#each jobFormOptions.contractType}}
          <label class="flex items-center gap-3 px-4 py-3 border-2 border-[#e0e0e0] mb-2 cursor-pointer hover:border-[#0a0a0a] transition-colors duration-75 text-base has-checked:border-[#0a0a0a]">
            <input
              type="radio"
              name="contractType"
              value="{{this}}"
              class="w-5 h-5 cursor-pointer accent-[#0f62fe]"
              required
              {{#if (eq ../values.contractType this)}}checked{{/if}}
            />
            {{this}}
          </label>
        {{/each}}
      </fieldset>
    </div>
  </div>

  {{!-- Location split into Province then City (both radio groups) --}}
  <div class="step" hidden>
    <div class="step__content">
      <fieldset>
        <legend>Province</legend>

        {{#each jobFormOptions.province}}
          <label class="flex items-center gap-3 px-4 py-3 border-2 border-[#e0e0e0] mb-2 cursor-pointer hover:border-[#0a0a0a] transition-colors duration-75 text-base has-checked:border-[#0a0a0a]">
            <input
              type="radio"
              name="province"
              value="{{this}}"
              class="w-5 h-5 cursor-pointer accent-[#0f62fe]"
              required
              {{#if (eq ../values.province this)}}checked{{/if}}
            />
            {{this}}
          </label>
        {{/each}}
      </fieldset>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <fieldset>
        <legend>City</legend>

        {{#each jobFormOptions.city}}
          <label class="flex items-center gap-3 px-4 py-3 border-2 border-[#e0e0e0] mb-2 cursor-pointer hover:border-[#0a0a0a] transition-colors duration-75 text-base has-checked:border-[#0a0a0a]">
            <input
              type="radio"
              name="city"
              value="{{this}}"
              class="w-5 h-5 cursor-pointer accent-[#0f62fe]"
              required
              {{#if (eq ../values.city this)}}checked{{/if}}
            />
            {{this}}
          </label>
        {{/each}}
      </fieldset>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <fieldset>
        <legend>Korean proficiency</legend>

        {{#each jobFormOptions.koreanProficiency}}
          <label class="flex items-center gap-3 px-4 py-3 border-2 border-[#e0e0e0] mb-2 cursor-pointer hover:border-[#0a0a0a] transition-colors duration-75 text-base has-checked:border-[#0a0a0a]">
            <input
              type="radio"
              name="koreanProficiency"
              value="{{value}}"
              class="w-5 h-5 cursor-pointer accent-[#0f62fe]"
              required
              {{#if (eq (toString ../values.koreanProficiency) (toString value))}}checked{{/if}}
            />
            {{label}}
          </label>
        {{/each}}
      </fieldset>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <fieldset>
        <legend>English proficiency</legend>

        {{#each jobFormOptions.englishProficiency}}
          <label class="flex items-center gap-3 px-4 py-3 border-2 border-[#e0e0e0] mb-2 cursor-pointer hover:border-[#0a0a0a] transition-colors duration-75 text-base has-checked:border-[#0a0a0a]">
            <input
              type="radio"
              name="englishProficiency"
              value="{{value}}"
              class="w-5 h-5 cursor-pointer accent-[#0f62fe]"
              required
              {{#if (eq (toString ../values.englishProficiency) (toString value))}}checked{{/if}}
            />
            {{label}}
          </label>
        {{/each}}
      </fieldset>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <div>
        <label for="otherLanguages">Other languages</label>
        <input
          id="otherLanguages"
          name="otherLanguages"
          type="text"
          class="text-[19px] px-3 py-2 border-2 border-[#393939] bg-white text-[#0a0a0a] leading-relaxed appearance-none rounded-none placeholder:text-[#a8a8a8] focus:outline-none"
          value="{{values.otherLanguages}}"
        />
        {{#if fieldErrors.otherLanguages}}
          <div data-error="otherLanguages">{{fieldErrors.otherLanguages.[0]}}</div>
        {{/if}}
      </div>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <fieldset>
        <legend>Visa sponsorship</legend>

        {{#each jobFormOptions.visaSponsorship}}
          <label class="flex items-center gap-3 px-4 py-3 border-2 border-[#e0e0e0] mb-2 cursor-pointer hover:border-[#0a0a0a] transition-colors duration-75 text-base has-checked:border-[#0a0a0a]">
            <input
              type="radio"
              name="visaSponsorship"
              value="{{this}}"
              class="w-5 h-5 cursor-pointer accent-[#0f62fe]"
              required
              {{#if (eq ../values.visaSponsorship this)}}checked{{/if}}
            />
            {{this}}
          </label>
        {{/each}}
      </fieldset>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <fieldset>
        <legend>Start date</legend>

        {{#each jobFormOptions.startDate}}
          <label class="flex items-center gap-3 px-4 py-3 border-2 border-[#e0e0e0] mb-2 cursor-pointer hover:border-[#0a0a0a] transition-colors duration-75 text-base has-checked:border-[#0a0a0a]">
            <input
              type="radio"
              name="startDate"
              value="{{this}}"
              class="w-5 h-5 cursor-pointer accent-[#0f62fe]"
              required
              {{#if (eq ../values.startDate this)}}checked{{/if}}
            />
            {{this}}
          </label>
        {{/each}}
      </fieldset>
    </div>
  </div>

  <div class="step" hidden>
    <div class="step__content">
      <div>
        <label for="fullDescription">Full description</label>
        <textarea
          id="fullDescription"
          name="fullDescription"
          required
        >{{values.fullDescription}}</textarea>
        {{#if fieldErrors.fullDescription}}
          <div data-error="fullDescription">{{fieldErrors.fullDescription.[0]}}</div>
        {{/if}}
      </div>
    </div>
  </div>

  <nav class="step__nav p-2">
    <button type="button" class="btn-back-to-review px-5 py-3 bg-[#0f62fe] text-white text-[16px] leading-none font-semibold tracking-[0.01em] shadow-[inset_0_-3px_0_#0043ce] hover:bg-[#0043ce] hover:shadow-[inset_0_-3px_0_#002590] active:translate-y-0.5 active:shadow-none transition-all duration-75 hover:cursor-pointer" hidden>Apply changes</button>
  </nav>


  <div class="review" hidden>
    <button type="submit" class="btn-confirm px-5 py-3 bg-[#00703c] text-white text-[16px] leading-none font-semibold tracking-[0.01em] shadow-[inset_0_-3px_0_#005a30] hover:bg-[#005a30] hover:shadow-[inset_0_-3px_0_#003d20] active:translate-y-0.5 active:shadow-none transition-all duration-75 hover:cursor-pointer">Save Changes</button>
  </div>

</form>

<script src="/edit-steps.js" defer></script>
